-- =============================================
-- AUTO ĐÁNH XA NPC - SIÊU ĐƠN GIẢN (Blox Fruits 2026)
-- Chỉ đánh xa, không bay không gì hết - Grok fix cuối
-- =============================================

local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")

local player = Players.LocalPlayer
local CommF = ReplicatedStorage:FindFirstChild("Remotes", true):FindFirstChild("CommF_")

print("✅ AUTO ĐÁNH XA BẬT - Đứng gần NPC là exp vào liền!")

RunService.Heartbeat:Connect(function()
	if not player.Character or not player.Character:FindFirstChild("HumanoidRootPart") then return end
	
	local hrp = player.Character.HumanoidRootPart
	local nearest, minDist = nil, math.huge
	
	for _, enemy in ipairs(Workspace.Enemies:GetChildren()) do
		if enemy:IsA("Model") and enemy:FindFirstChild("Humanoid") and enemy.Humanoid.Health > 0 then
			-- Bỏ qua NPC nhận quest
			if enemy:FindFirstChildWhichIsA("BillboardGui") or enemy.Name:lower():find("quest") or enemy.Name:lower():find("giver") then
				continue
			end
			
			local root = enemy:FindFirstChild("HumanoidRootPart")
			if root then
				local dist = (root.Position - hrp.Position).Magnitude
				if dist < minDist and dist < 100 then  -- đánh xa trong 100 studs
					minDist = dist
					nearest = enemy
				end
			end
		end
	end
	
	if nearest then
		local npcRoot = nearest.HumanoidRootPart
		
		-- Nhìn về NPC để đánh xa
		hrp.CFrame = CFrame.lookAt(hrp.Position, npcRoot.Position)
		
		-- ĐÁNH XA (remote + tool)
		pcall(function()
			CommF:InvokeServer("Melee")
			CommF:InvokeServer("Damage", nearest)  -- args phổ biến 2026
		end)
		
		local tool = player.Character:FindFirstChildOfClass("Tool")
		if tool then tool:Activate() end
	end
end)

print("Chạy ngon thì exp tăng. Không tăng thì báo tao, đổi executor Delta mới nhất là xong.")
